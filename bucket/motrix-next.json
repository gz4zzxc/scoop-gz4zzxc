{
    "version": "3.6.10",
    "description": "Motrix 的现代重写版下载管理器，基于 Tauri 与 aria2",
    "homepage": "https://github.com/AnInsomniacy/motrix-next",
    "license": {
        "identifier": "MIT",
        "url": "https://github.com/AnInsomniacy/motrix-next/blob/main/LICENSE"
    },
    "notes": [
        "使用 7-Zip 直接解包官方 Windows NSIS 安装器到 Scoop 目录，不写入 Program Files，也不依赖 UAC",
        "上游未进行代码签名，首次下载或运行时可能被浏览器或杀毒软件提示风险",
        "更新时如提示文件占用，请先退出 Motrix Next 托盘与主程序后再执行 scoop update motrix-next"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v3.6.10/MotrixNext_3.6.10_x64-setup.exe",
            "hash": "5995a90b78597ae1f9f8ce69a2ea72aad46ed67a83a05e0e36c11d4a913e55ff"
        }
    },
    "installer": {
        "script": [
            "$installer = Get-ChildItem -Path $dir -Filter 'MotrixNext_*_x64-setup.exe' -File | Select-Object -First 1 -ExpandProperty FullName",
            "if (-not (Test-Path $installer)) { throw '未找到 Motrix Next 安装器文件' }",
            "& 7z x $installer -o\"$dir\" -y | Out-Null",
            "if (-not (Test-Path (Join-Path $dir 'motrix-next.exe'))) { throw '解包失败：未找到 motrix-next.exe' }",
            "@('$PLUGINSDIR', 'uninstall.exe') | ForEach-Object { if (Test-Path (Join-Path $dir $_)) { Remove-Item (Join-Path $dir $_) -Recurse -Force -ErrorAction SilentlyContinue } }",
            "Remove-Item $installer -Force -ErrorAction SilentlyContinue"
        ]
    },
    "bin": "motrix-next.exe",
    "shortcuts": [
        [
            "motrix-next.exe",
            "Motrix Next"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/AnInsomniacy/motrix-next/releases/latest",
        "jsonpath": "$.tag_name",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v$version/MotrixNext_$version_x64-setup.exe"
            }
        },
        "hash": {
            "mode": "download"
        }
    }
}
