{
    "version": "2.1.54",
    "description": "开源的多模型 AI 聊天与增强工具 (Desktop Electron 版)",
    "homepage": "https://github.com/lobehub/lobehub",
    "license": {
        "identifier": "Apache-2.0",
        "url": "https://github.com/lobehub/lobe-chat/blob/main/LICENSE"
    },
    "notes": [
        "此包使用官方 Windows 安装程序 (electron-builder NSIS)，支持 /S 静默安装",
        "首次启动会创建用户数据目录于 %APPDATA% 或 %LOCALAPPDATA%",
        "更新时如有进程占用，请先退出托盘后再执行 scoop update lobehub"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/lobehub/lobehub/releases/download/v2.1.54/LobeHub-2.1.54-setup.exe",
            "hash": "8dcaedb1cb615dc21019d44f9f098a1f8176ca85e0dc840ca51df5525a940791"
        }
    },
    "installer": {
        "args": [
            "/S",
            "/D=$dir"
        ]
    },
    "bin": [
        "LobeHub.exe",
        "lobehub"
    ],
    "shortcuts": [
        [
            "LobeHub.exe",
            "LobeChat"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/lobehub/lobehub/releases/latest",
        "jsonpath": "$.tag_name",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/lobehub/lobehub/releases/download/v$version/LobeHub-$version-setup.exe"
            }
        },
        "hash": {
            "mode": "download"
        }
    }
}
